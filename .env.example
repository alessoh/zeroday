# Anthropic API key — required for all LLM calls (CVE parsing, reachability,
# patch generation, and PR writing).
# Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# GitHub personal access token — required for reading repository contents via
# the GitHub REST API. Must have at minimum the `repo` (read) scope for private
# repos, or no scope for public repos (but a token still avoids rate limits).
# Obtain from https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...
